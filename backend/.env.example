APP_NAME=AI Quiz Generator Platform
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=replace_with_a_very_strong_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_quiz

ALLOWED_EXTENSIONS=["pdf","docx"]
MAX_UPLOAD_SIZE_MB=15

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=ai-quiz-files
S3_REGION=us-east-1

CHROMA_PERSIST_DIRECTORY=./chroma_data
EMBEDDINGS_MODEL=text-embedding-3-small

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

FRONTEND_URL=http://localhost:3000
RATE_LIMIT_QUIZ_GENERATION=10/minute
